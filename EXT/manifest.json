{
  "name": "Data Scope",
  "description": "Base Level Extension",
  "version": "0.2",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://*.bing.com/*",
    "https://www.perplexity.ai/*",
    "https://*.perplexity.ai/*",
    "https://www.meta.ai/*",
    "https://chat.z.ai/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://*.onrender.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/hello_extensions.png"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/loader.js"],
      "type": "module",
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content/modelDetector.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/content.js",
        "content/auth.js",
        "content/buttonDetector.js",
        "content/editorDetector.js",
        "content/modelDetector.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://datascope-web-pruebas.onrender.com/*",
      "https://datascope-orhf.onrender.com/*"
    ]
  }
}