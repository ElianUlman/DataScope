{
  "name": "Data Scope",
  "description": "Base Level Extension",
  "version": "0.1",
  "manifest_version": 3,
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://*.bing.com/*",
    "https://www.perplexity.ai/*",
    "https://*.perplexity.ai/*"
  ],
  "action": {
    "default_popup": "hello.html",
    "default_icon": "hello_extensions.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://*.bing.com/*",
        "https://www.perplexity.ai/*",
        "https://*.perplexity.ai/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}